{
  "manifest_version": 3,
  "name": "Dopes Gatekeeper",
  "version": "1.0",
  "description": "A Chrome extension to limit time spent on websites and show rest overlays.",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.twitch.tv/*",
        "*://*.instagram.com/*",
        "*://*.iyf.tv/*",
        "*://*.bilibili.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dopes Gatekeeper"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["png/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
